<div class="experience">
  {% assign cv = site.data.cv.cv %}
  {% assign experiences = cv.sections['Experience'] %}
  {% if include.limit %}
    {% assign exp_limit = include.limit %}
  {% else %}
    {% assign exp_limit = experiences.size %}
  {% endif %}
  {% for exp in experiences limit: exp_limit %}
    <div class="experience-item mb-3">
      <div class="d-flex flex-column flex-sm-row justify-content-between">
        <div>
          <strong>{{ exp.position }}</strong>
          <br>
          <span class="text-muted">{{ exp.company }}{% if exp.location != "" and exp.location != nil %} · {{ exp.location }}{% endif %}</span>
        </div>
        <div class="text-muted text-sm-right mt-1 mt-sm-0" style="white-space: nowrap;">
          {% if exp.date_display %}{{ exp.date_display }}{% else %}{{ exp.start_date | date: '%Y' }}–{% if exp.end_date == "" or exp.end_date == nil %}Present{% else %}{{ exp.end_date | date: '%Y' }}{% endif %}{% endif %}
        </div>
      </div>
      {% if exp.summary != "" and exp.summary != nil %}
        <p class="mt-1 mb-0 font-weight-light">{{ exp.summary }}</p>
      {% endif %}
    </div>
  {% endfor %}
</div>
